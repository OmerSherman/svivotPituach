              "raw": "{\n  \"city_id\": 2,\n  \"name\": \"Test Attraction\",\n  \"name_he\": \"אטרקציית בדיקה\",\n  \"type\": \"site\",\n  \"description_he\": \"תיאור לבדיקה\",\n  \"image_url\": \"https://loremflickr.com/800/600/test,buenosaires/all\"\n}"
