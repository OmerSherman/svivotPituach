{
  "info": {
    "name": "Shvil HaTahina — Assignment 4",
    "description": "Full REST coverage for Shvil HaTahina (Assignment 4).\n\nPrerequisites:\n1. cd backend && npm run db:setup && npm start\n2. Import this collection into Postman\n3. Run \"POST login — success (user)\" or \"POST login — success (admin)\" first — they save userId/userRole to collection variables\n4. Use Collection Runner on the whole collection — each request runs an automatic test on the { success, data, error } envelope\n\nSeed passwords: 123456 for all users (michal@example.com = admin, user@example.com = user id 4).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "userId", "value": "4" },
    { "key": "userRole", "value": "user" }
  ],
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const ct = pm.response.headers.get('Content-Type') || '';",
          "if (ct.includes('application/json')) {",
          "  const body = pm.response.json();",
          "  pm.test('API envelope (success, data, error)', function () {",
          "    pm.expect(body).to.have.property('success');",
          "    pm.expect(body).to.have.property('data');",
          "    pm.expect(body).to.have.property('error');",
          "  });",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST register — success",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"dana\",\n  \"lastName\": \"levi\",\n  \"email\": \"dana-test@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "POST register — missing fields",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"dana\"\n}" }
          }
        },
        {
          "name": "POST login — success (admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && j.data && j.data.userId) {",
                  "  pm.collectionVariables.set('userId', String(j.data.userId));",
                  "  pm.collectionVariables.set('userRole', j.data.userRole);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"michal@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "POST login — success (user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const j = pm.response.json();",
                  "if (j.success && j.data && j.data.userId) {",
                  "  pm.collectionVariables.set('userId', String(j.data.userId));",
                  "  pm.collectionVariables.set('userRole', j.data.userRole);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "POST login — wrong password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"michal@example.com\",\n  \"password\": \"wrong\"\n}"
            }
          }
        },
        {
          "name": "POST logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": []
          }
        }
      ]
