{
  "info": {
    "name": "Shvil HaTahina — Assignment 4",
    "description": "REST API for Shvil HaTahina. Test password for all users: 123456",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api" },
    { "key": "userId", "value": "1" },
    { "key": "userRole", "value": "admin" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST register — success",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"dana\",\n  \"lastName\": \"levi\",\n  \"email\": \"dana-test@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "POST register — missing fields",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/register",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"dana\"\n}" }
          }
        },
        {
          "name": "POST login — success (admin)",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"michal@example.com\",\n  \"password\": \"123456\"\n}"
            }
          }
        },
        {
          "name": "POST login — wrong password",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"michal@example.com\",\n  \"password\": \"wrong\"\n}"
            }
          }
        },
        {
          "name": "POST logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout",
            "header": []
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "GET me",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/me",
            "header": [
              { "key": "x-user-id", "value": "{{userId}}" },
              { "key": "x-user-role", "value": "{{userRole}}" }
            ]
          }
        },
        {
          "name": "GET all users — admin",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "x-user-role", "value": "admin" }]
          }
        },
        {
          "name": "GET all users — forbidden",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users",
            "header": [{ "key": "x-user-role", "value": "user" }]
          }
        },
        {
          "name": "GET user by id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/1",
            "header": []
          }
        },
        {
          "name": "GET user not found",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/users/999",
            "header": []
          }
        },
        {
          "name": "POST create user — admin",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/users",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "admin" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"firstName\": \"yael\",\n  \"lastName\": \"cohen\",\n  \"userRole\": \"user\"\n}"
            }
          }
        },
        {
          "name": "PUT update user — manager",
          "request": {
            "method": "PUT",
            "url": "{{baseUrl}}/users/4",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-user-role", "value": "manager" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"updated\"\n}" }
          }
        },
        {
          "name": "DELETE user — admin",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/99",
            "header": [{ "key": "x-user-role", "value": "admin" }]
          }
        },
        {
          "name": "DELETE user — self",
          "request": {
            "method": "DELETE",
            "url": "{{baseUrl}}/users/4",
            "header": [
              { "key": "x-user-role", "value": "user" },
              { "key": "x-user-id", "value": "4" }
            ]
          }
        }
      ]
    },
    {
      "name": "Cities",
      "item": [
        {
          "name": "GET all cities",
          "request": { "method": "GET", "url": "{{baseUrl}}/cities", "header": [] }
        },
        {
          "name": "GET search — English",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/cities/search?q=buenos",
              "host": ["{{baseUrl}}"],
              "path": ["cities", "search"],
              "query": [{ "key": "q", "value": "buenos" }]
            },
            "header": []
          }
        },
        {
          "name": "GET search — Hebrew",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/cities/search?q=ריו",
              "host": ["{{baseUrl}}"],
              "path": ["cities", "search"],
              "query": [{ "key": "q", "value": "ריו" }]
            },
            "header": []
          }
        },
        {
          "name": "GET search — no query",
          "request": { "method": "GET", "url": "{{baseUrl}}/cities/search", "header": [] }
        },
        {
          "name": "GET city by id",
          "request": { "method": "GET", "url": "{{baseUrl}}/cities/1", "header": [] }
        },
        {
          "name": "GET city not found",
          "request": { "method": "GET", "url": "{{baseUrl}}/cities/999", "header": [] }
        }
      ]
    },
    {
